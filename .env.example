GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
RAG_VECTOR_DB_PATH=./chromadb
RAG_TOP_K=5
RAG_MODEL=gemini-2.5-flash
RAG_ENABLE_VECTOR_SEARCH=false
RAG_ENABLE_VERTEX_RERANK=false
VERTEX_RERANK_MODEL=gemini-2.5-flash
VERTEX_RERANK_MIN_SCORE=0.45
VERTEX_RERANK_HIGH_CONFIDENCE_SCORE=0.80
RAG_ENABLE_BIGQUERY_INGESTION=false
BIGQUERY_DATASET=
BIGQUERY_TABLES=
BIGQUERY_LIMIT_PER_TABLE=500
BIGQUERY_PARTITION_COLUMN=
BIGQUERY_PARTITION_START=
BIGQUERY_PARTITION_END=
BIGQUERY_USE_INCREMENTAL_CHECKPOINT=true
BIGQUERY_CHECKPOINT_PATH=./logs/bq_ingestion_checkpoint.json
GROUNDEDNESS_MIN_PASS_RATE=0.67
